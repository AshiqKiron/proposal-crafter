{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "proposal-crafter/table",
    "title": "Table",
    "category": "proposal-crafter",
    "description": "Create a table for your proposal",
    "keywords": [
        "table",
        "data",
        "row",
        "column"
    ],
    "textdomain": "proposal-crafter",
    "attributes": {
        "uniqueId": {
            "type": "string",
            "default": ""
        },
        "css": {
            "type": "string",
            "default": ""
        },
        "headerVisible": {
            "type": "boolean",
            "default": true
        },
        "fontFamily": {
            "type": "string",
            "default": ""
        },
        "fontSize": {
            "type": "number",
            "default": 16
        },
        "fontSizeTablet": {
            "type": "number"
        },
        "fontSizeMobile": {
            "type": "number"
        },
        "head": {
            "type": "array",
            "default": []
        },
        "body": {
            "type": "array",
            "default": []
        },
        "borderStyle": {
            "type": "string",
            "default": "none"
        },
        "borderColor": {
            "type": "string",
            "default": "#000000"
        },
        "borderWidth": {
            "type": "object",
            "default": {
                "top": "0px",
                "right": "0px",
                "bottom": "0px",
                "left": "0px"
            }
        },
        "borderWidthTablet": {
            "type": "object"
        },
        "borderWidthMobile": {
            "type": "object"
        },
        "padding": {
            "type": "object",
            "default": {
                "top": "0px",
                "right": "0px",
                "bottom": "0px",
                "left": "0px"
            }
        },
        "paddingTablet": {
            "type": "object"
        },
        "paddingMobile": {
            "type": "object"
        },
        "margin": {
            "type": "object",
            "default": {
                "top": "0px",
                "right": "0px",
                "bottom": "0px",
                "left": "0px"
            }
        },
        "marginTablet": {
            "type": "object"
        },
        "marginMobile": {
            "type": "object"
        },
        "background": {
            "type": "object",
            "default": {
                "type": "color",
                "repeat": "no-repeat",
                "size": "cover",
                "value": ""
            }
        },
        "headerFontWeight": {
            "type": "string",
            "default": "600"
        },
        "headerPadding": {
            "type": "object",
            "default": {
                "top": "10px",
                "right": "10px",
                "bottom": "10px",
                "left": "10px"
            }
        },
        "headerPaddingTablet": {
            "type": "object"
        },
        "headerPaddingMobile": {
            "type": "object"
        },
        "headerAlignment": {
            "type": "string",
            "default": "left"
        },
        "headerBackground": {
            "type": "string",
            "default": ""
        },
        "headerColor": {
            "type": "string",
            "default": ""
        },
        "bodyBackgroundOdd": {
            "type": "string",
            "default": ""
        },
        "bodyBackgroundEven": {
            "type": "string",
            "default": ""
        },
        "bodyColorOdd": {
            "type": "string",
            "default": ""
        },
        "bodyColorEven": {
            "type": "string",
            "default": ""
        },
        "bodyFontWeight": {
            "type": "string",
            "default": "400"
        },
        "bodyPadding": {
            "type": "object",
            "default": {
                "top": "10px",
                "right": "10px",
                "bottom": "10px",
                "left": "10px"
            }
        },
        "bodyPaddingTablet": {
            "type": "object"
        },
        "bodyPaddingMobile": {
            "type": "object"
        },
        "bodyAlignment": {
            "type": "string",
            "default": "left"
        }
    },
    "supports": {
        "html": false,
        "anchor": true,
        "align": false
    },
    "style": [
        "file:style.css"
    ],
    "editorStyle": [
        "file:editor.css"
    ]
}