{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "proposal-crafter/image",
    "title": "Image",
    "category": "proposal-crafter",
    "description": "Upload an image.",
    "keywords": [
        "image",
        "upload",
        "media"
    ],
    "textdomain": "proposal-crafter",
    "attributes": {
        "uniqueId": {
            "type": "string",
            "default": ""
        },
        "css": {
            "type": "string",
            "default": ""
        },
        "imageId": {
            "type": "number"
        },
        "imageUrl": {
            "type": "string",
            "default": ""
        },
        "imageAlt": {
            "type": "string",
            "default": ""
        },
        "borderStyle": {
            "type": "string",
            "default": "none"
        },
        "borderColor": {
            "type": "string",
            "default": "#000000"
        },
        "borderWidth": {
            "type": "object",
            "default": {
                "top": "0px",
                "right": "0px",
                "bottom": "0px",
                "left": "0px"
            }
        },
        "borderWidthTablet": {
            "type": "object"
        },
        "borderWidthMobile": {
            "type": "object"
        },
        "padding": {
            "type": "object",
            "default": {
                "top": "0px",
                "right": "0px",
                "bottom": "0px",
                "left": "0px"
            }
        },
        "paddingTablet": {
            "type": "object"
        },
        "paddingMobile": {
            "type": "object"
        },
        "margin": {
            "type": "object",
            "default": {
                "top": "0px",
                "right": "0px",
                "bottom": "0px",
                "left": "0px"
            }
        },
        "marginTablet": {
            "type": "object"
        },
        "marginMobile": {
            "type": "object"
        },
        "background": {
            "type": "object",
            "default": {
                "type": "color",
                "repeat": "no-repeat",
                "size": "cover",
                "value": ""
            }
        },
        "backgroundOverlay": {
            "type": "string"
        },
        "positionX": {
            "type": "number",
            "default": 0
        },
        "positionXTablet": {
            "type": "number"
        },
        "positionXMobile": {
            "type": "number"
        },
        "positionY": {
            "type": "number",
            "default": 0
        },
        "positionYTablet": {
            "type": "number"
        },
        "positionYMobile": {
            "type": "number"
        },
        "positionType": {
            "type": "string",
            "default": "static"
        },
        "positionTypeTablet": {
            "type": "string"
        },
        "positionTypeMobile": {
            "type": "string"
        },
        "width": {
            "type": "number",
            "default": 200
        },
        "widthTablet": {
            "type": "number"
        },
        "widthMobile": {
            "type": "number"
        },
        "height": {
            "type": "number",
            "default": 200
        },
        "heightTablet": {
            "type": "number"
        },
        "heightMobile": {
            "type": "number"
        }
    },
    "supports": {
        "html": false,
        "anchor": true,
        "align": false
    },
    "style": [
        "file:style.css"
    ],
    "editorStyle": [
        "file:editor.css"
    ]
}