{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "proposal-crafter/client-email",
	"title": "Client Email",
	"category": "proposal-crafter",
	"description": "Add client email for your proposal",
	"keywords": [ "email", "proposal", "client", "meta", "cover" ],
	"textdomain": "proposal-crafter",
	"attributes": {
		"uniqueId": {
			"type": "string",
			"default": ""
		},
		"css": {
			"type": "string",
			"default": ""
		},
		"borderStyle": {
			"type": "string",
			"default": "none"
		},
		"borderColor": {
			"type": "string",
			"default": "#000000"
		},
		"borderWidth": {
			"type": "object",
			"default": {
				"top": "0px",
				"right": "0px",
				"bottom": "0px",
				"left": "0px"
			}
		},
		"borderWidthTablet": {
			"type": "object"
		},
		"borderWidthMobile": {
			"type": "object"
		},
		"content": {
			"type": "string",
			"default": "Client Email"
		},
		"alignment": {
			"type": "string",
			"default": "left"
		},
		"alignmentTablet": {
			"type": "string"
		},
		"alignmentMobile": {
			"type": "string"
		},
		"fontSize": {
			"type": "number",
			"default": 16
		},
		"fontSizeTablet": {
			"type": "number"
		},
		"fontSizeMobile": {
			"type": "number"
		},
		"fontWeight": {
			"type": "string",
			"default": "400"
		},
		"fontFamily": {
			"type": "string",
			"default": ""
		},
		"background": {
			"type": "object",
			"default": {
				"type": "color",
				"repeat": "no-repeat",
				"size": "cover",
				"value": ""
			}
		},
		"color": {
			"type": "string",
			"default": "#000000"
		},
		"padding": {
			"type": "object",
			"default": {
				"top": "0px",
				"right": "0px",
				"bottom": "0px",
				"left": "0px"
			}
		},
		"paddingTablet": {
			"type": "object"
		},
		"paddingMobile": {
			"type": "object"
		},
		"margin": {
			"type": "object",
			"default": {
				"top": "0px",
				"right": "0px",
				"bottom": "0px",
				"left": "0px"
			}
		},
		"marginTablet": {
			"type": "object"
		},
		"marginMobile": {
			"type": "object"
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": false
	},
	"style": [ "file:style.css" ],
	"editorStyle": [ "file:editor.css" ],
	"render": "file:render.php"
}
